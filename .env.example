# ============================================================================
# LeadForge AI — environment variables
# Copy to .env and fill in. Never commit .env.
# ============================================================================

# ---- App ----
APP_ENV=development
APP_NAME=LeadForge AI
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3001,https://app.leadforge.ai

# ---- Database ----
POSTGRES_USER=leadforge
POSTGRES_PASSWORD=leadforge
POSTGRES_DB=leadforge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://leadforge:leadforge@postgres:5432/leadforge

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Clerk (auth) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWKS_URL=https://clerk.YOUR_FRONTEND.com/.well-known/jwks.json
CLERK_ISSUER=https://clerk.YOUR_FRONTEND.com
CLERK_WEBHOOK_SECRET=whsec_xxx

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---- LLM provider ----
# Set EITHER OPENAI_API_KEY or GEMINI_API_KEY (OpenAI wins if both are set).
# If neither is set the system runs in demo mode with canned fixtures.

# Option A — OpenAI (paid; ~$0.01–0.10 per call). Sign up: platform.openai.com
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-large
OPENAI_EMBEDDING_DIM=1536

# Option B — Google Gemini (generous free tier). Sign up: aistudio.google.com/apikey
# Uses Gemini's OpenAI-compatible endpoint so no code changes required.
GEMINI_API_KEY=
# flash-lite has the most generous free-tier quota; gemini-2.5-flash often 429s on free tier
GEMINI_MODEL_REASONING=gemini-2.5-flash-lite
GEMINI_MODEL_FAST=gemini-2.5-flash-lite
GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# Mistral (OpenAI-compatible, free tier). Priority: OpenAI > Mistral > Gemini > demo.
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL_REASONING=mistral-small-latest
MISTRAL_MODEL_FAST=mistral-small-latest

# ---- Search providers ----
TAVILY_API_KEY=tvly-xxx
SERPER_API_KEY=xxx

# ---- Email validation ----
HUNTER_API_KEY=xxx
NEVERBOUNCE_API_KEY=xxx

# ---- Gmail sending + reply detection ----
# Create a 16-char App Password at https://myaccount.google.com/apppasswords (needs 2FA)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=LeadForge

# ---- Telegram notifications ----
# 1) @BotFather -> /newbot -> token   2) message the bot, then @userinfobot for your chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Storage (S3) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
S3_BUCKET=leadforge-uploads

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=LeadForge AI

# ---- Observability ----
SENTRY_DSN=
LOG_LEVEL=INFO

# ---- Feature flags ----
FEATURE_PLAYWRIGHT_SCRAPE=true
FEATURE_AI_CHAT=true
FEATURE_WORKFLOWS=true

# ---- Google Places (local-SMB discovery) ----
# Google Cloud project -> enable Places API (New) -> billing on -> create key
GOOGLE_MAPS_API_KEY=
